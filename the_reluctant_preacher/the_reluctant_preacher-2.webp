	<a href="#" class="back-top-btn" style="display: none;">このページのトップへ戻る</a>
	<script>
	$(function(){
	
		$btn_scroll_top = $('.back-top-btn');
		var btn_scroll_h_pos = 150;
		var scroll = false;
		if(navigator.userAgent.indexOf('Android') > -1){
			btn_scroll_h_pos = 160;
		}
		btn_scroll_h_pos = btn_scroll_h_pos + 30;
	
		$btn_scroll_top.on('touchend',function(){
			event.preventDefault();
			$(this).queue([]);
			$(this).stop();
			$(this).hide();
			scroll = true;
			$("html,body").animate({scrollTop:0},function(event){
				scroll = false;
			});
		});
	
		var moveHandler = function(){
								var scroll_top_pos = 80;
								if($(window).scrollTop() > scroll_top_pos){
				if(!scroll){
					$btn_scroll_top.queue([]);
					$btn_scroll_top.stop();
					$btn_scroll_top.css('opacity','0.9');
					$btn_scroll_top.show();
					var w_pos = $('body').offset()['left']+ $('body').outerWidth()-54;
					$btn_scroll_top.css({position:'fixed',top:$(window).innerHeight()-btn_scroll_h_pos,left: + w_pos}) ;
					$btn_scroll_top.animate({ opacity: 'hide',}, { duration: 3000, easing: 'swing', } );
				}
			}else{
				$btn_scroll_top.queue([]);
				$btn_scroll_top.stop();
				$btn_scroll_top.hide();
			}
		}
	
		$(window).on('scroll',moveHandler);
		$(window).on('resize',moveHandler);
	
		moveHandler();
	
	})
	</script>
	
